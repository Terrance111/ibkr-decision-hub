# =============================================================================
# IBKR Flex — required
# =============================================================================
# Client Portal → Reporting → Flex Web Service: create token, enable Web Service.
IBKR_FLEX_TOKEN=your_flex_token_here

# Activity Flex query used for TRADE history only (SendRequest with fd/td date range).
# Must return execution/trade columns compatible with src/data/ibkr_fetch.py (e.g. Symbol, date, Buy/Sell, Quantity, Trade Price, Proceeds).
IBKR_FLEX_QUERY_ID=your_trades_flex_query_id_here

# Activity Flex query used for CURRENT HOLDINGS (Open Positions snapshot — SendRequest without fd/td).
# Strongly recommended: a dedicated query that only includes the Open Positions section and the columns you want in the UI.
# If unset, the app falls back to IBKR_FLEX_QUERY_ID for positions (only works if that template returns a usable Open Positions CSV).
IBKR_FLEX_POSITIONS_QUERY_ID=your_open_positions_flex_query_id_here

# =============================================================================
# IBKR Flex — optional (HTTP / CSV / rate limits)
# =============================================================================
# Base SendRequest URL only (no ?t=...). Params t, q, v, and optional fd/td are added in code.
# IBKR_FLEX_SEND_REQUEST_URL=https://ndcdyn.interactivebrokers.com/AccountManagement/FlexWebService/SendRequest

# Rows to skip before the CSV header when parsing Flex GetStatement bodies (integer). If unset, tries 7, 0, 1, …
# IBKR_FLEX_CSV_SKIP_ROWS=7

# GetStatement polling (1019 = generation in progress).
# IBKR_FLEX_GETSTATEMENT_RETRIES=50
# IBKR_FLEX_GETSTATEMENT_SLEEP=2
# IBKR_FLEX_GETSTATEMENT_SLEEP_INPROGRESS=5

# SendRequest retries: 1018 rate limit uses IBKR_FLEX_RATE_LIMIT_SLEEP (default 15s).
# IBKR_FLEX_SENDREQUEST_RETRIES=8
# IBKR_FLEX_SENDREQUEST_SLEEP=2
# IBKR_FLEX_RATE_LIMIT_SLEEP=20

# Pacing: pause between trade-history segments; extra pause after all segments before positions Flex.
# IBKR_FLEX_SEGMENT_SLEEP=1.1
# IBKR_FLEX_AFTER_SEGMENTS_SLEEP=3

# Trade history: max calendar span per SendRequest fd/td (IBKR Activity queries are often capped at ~365 days).
# The app loops with multiple SendRequests until caught up to today. Default 364; set 360–365 if your portal limit differs.
# IBKR_FLEX_TRADE_SEGMENT_DAYS=364

# IBKR requires User-Agent on Flex requests; a default is used if unset.
# IBKR_FLEX_USER_AGENT=MyApp/1.0

# =============================================================================
# Trade cache (optional)
# =============================================================================
# Explicit earliest date for trade history fetching (YYYYMMDD).
# Takes precedence over IBKR_TRADE_HISTORY_LOOKBACK_DAYS.
# Set this to your account opening date to avoid thousands of empty Flex segments.
# Example (recommended for accounts opened in 2024):
# IBKR_TRADE_HISTORY_START_DATE=20240101

# First full fetch when cache/trade_history.csv does not exist (default ~730 days).
# Ignored if IBKR_TRADE_HISTORY_START_DATE is set.
# IBKR_TRADE_HISTORY_LOOKBACK_DAYS=3650

# Incremental sync: re-fetch this many days before (last_trade_date + 1) for amended Flex rows. Default 7; 0 disables.
# IBKR_TRADE_INCREMENTAL_OVERLAP_DAYS=7

# =============================================================================
# Local CSV snapshots (written under cache/ by the app)
# =============================================================================
# cache/trade_history.csv — standardized executions from the trades Flex query (fd/td).
# cache/open_positions_snapshot.csv — last Open Positions Flex snapshot (no fd/td). Loaded on startup;
#   use Streamlit **Refresh All Data** to pull Flex again. Diluted cost in Current Holdings still uses
#   trade_history.csv via process_trades, not the positions CSV.
